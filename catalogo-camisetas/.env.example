# Credenciales de Supabase (obligatorio)
# Copiá este archivo a .env y completá con tus valores:
#   1. Creá un proyecto en https://supabase.com
#   2. Andá a Project Settings > API
#   3. Copiá Project URL y anon public key

PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-publica
