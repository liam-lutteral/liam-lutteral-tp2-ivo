---
import Layout from "../layouts/Layout.astro";
import { tipoOptions } from "../data/camisetas.js";
---

<Layout title="Mi catálogo">
  <section class="dashboard-shell">
    <header class="dashboard-header">
      <div>
        <span class="eyebrow">Mi catálogo</span>
        <h1>Tus camisetas de fútbol.</h1>
        <p>Gestioná tu colección personal: cada usuario ve y edita solo sus propias camisetas.</p>
      </div>
      <div class="dashboard-cta">
        <a class="primary-button" href="/nueva">Nueva camiseta</a>
      </div>
    </header>

    <div class="dashboard-panel">
      <aside class="filter-card">
        <span class="eyebrow">Filtros</span>
        <h2>Buscar en tu colección</h2>
        <label>
          Buscar
          <input id="search" placeholder="Equipo, marca, temporada..." />
        </label>
        <label>
          Tipo de equipación
          <select id="filter-tipo">
            {tipoOptions.map((option) => (
              <option value={option}>{option}</option>
            ))}
          </select>
        </label>
      </aside>

      <div class="catalog-frame">
        <div class="catalog-topbar">
          <div>
            <span class="eyebrow">Catálogo</span>
            <p id="card-count">Cargando camisetas...</p>
          </div>
          <button id="refresh" class="icon-button" type="button">Actualizar</button>
        </div>

        <section id="camisetas" class="catalog-grid"></section>
        <p id="empty-hint" class="empty-hint" hidden>
          Todavía no tenés camisetas. <a href="/nueva">Agregá la primera</a>.
        </p>
      </div>
    </div>
  </section>
</Layout>

<script src="../scripts/dashboard.js"></script>

<style>
  .dashboard-shell {
    display: grid;
    gap: 28px;
  }

  .dashboard-header {
    display: flex;
    justify-content: space-between;
    gap: 24px;
    align-items: flex-start;
  }

  .dashboard-header h1 {
    margin: 0;
    font-size: clamp(2rem, 2.8vw, 3rem);
    line-height: 1.05;
  }

  .dashboard-header p {
    margin: 18px 0 0;
    max-width: 640px;
    color: #525252;
    line-height: 1.75;
  }

  .dashboard-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    align-items: center;
  }

  .primary-button,
  .secondary-button,
  .danger-button,
  .icon-button {
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    font-weight: 700;
    transition: transform 180ms ease, background 180ms ease;
    text-decoration: none;
    font-size: 1rem;
  }

  .primary-button {
    padding: 16px 26px;
    background: #111111;
    color: #ffffff;
  }

  .primary-button:hover,
  .secondary-button:hover,
  .icon-button:hover {
    transform: translateY(-1px);
  }

  .secondary-button,
  .icon-button {
    padding: 14px 24px;
    background: rgba(17, 17, 17, 0.06);
    color: #111111;
  }

  .danger-button {
    padding: 14px 24px;
    background: rgba(209, 47, 47, 0.1);
    color: #b42318;
  }

  .danger-button:hover {
    background: rgba(209, 47, 47, 0.18);
  }

  .dashboard-panel {
    display: grid;
    grid-template-columns: minmax(260px, 320px) minmax(0, 1fr);
    gap: 24px;
    align-items: start;
  }

  .filter-card {
    background: #ffffff;
    border-radius: 32px;
    padding: 28px;
    box-shadow: 0 30px 70px rgba(17, 17, 17, 0.08);
    position: sticky;
    top: 100px;
  }

  .filter-card h2 {
    margin: 12px 0 22px;
    font-size: 1.65rem;
  }

  label {
    display: grid;
    gap: 10px;
    font-weight: 600;
    color: #444444;
    margin-top: 18px;
  }

  input,
  select {
    width: 100%;
    border: 1px solid #e4ddd5;
    border-radius: 16px;
    padding: 16px 18px;
    background: #faf6ef;
    color: #111111;
    font-size: 1rem;
  }

  .catalog-frame {
    display: grid;
    gap: 20px;
  }

  .catalog-topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }

  .catalog-topbar p {
    margin: 8px 0 0;
    color: #666666;
  }

  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
  }

  .product-card {
    background: #ffffff;
    border-radius: 32px;
    overflow: hidden;
    border: 1px solid rgba(17, 17, 17, 0.04);
    box-shadow: 0 24px 50px rgba(17, 17, 17, 0.06);
    transition: transform 200ms ease, box-shadow 200ms ease;
  }

  .product-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 36px 90px rgba(17, 17, 17, 0.1);
  }

  .card-image {
    position: relative;
    height: 280px;
    background: #f6f1e7;
    overflow: hidden;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-tag {
    position: absolute;
    left: 22px;
    bottom: 22px;
    background: rgba(255, 255, 255, 0.92);
    border-radius: 999px;
    padding: 10px 14px;
    color: #111111;
    font-size: 0.88rem;
    font-weight: 700;
  }

  .card-body {
    padding: 26px;
    display: grid;
    gap: 14px;
  }

  h2 {
    margin: 0;
    font-size: 1.55rem;
    line-height: 1.1;
  }

  .card-desc {
    margin: 0;
    color: #5d5d5d;
    line-height: 1.75;
    min-height: 48px;
  }

  .meta-row {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    color: #828282;
    font-size: 0.94rem;
  }

  .action-row {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .secondary-button {
    flex: 1;
    text-align: center;
    padding: 14px 18px;
  }

  .danger-button {
    flex: 1;
    text-align: center;
  }

  .empty-state,
  .empty-hint {
    grid-column: 1 / -1;
    padding: 54px 24px;
    border-radius: 28px;
    background: #fff8f1;
    color: #6b6b6b;
    text-align: center;
    line-height: 1.75;
  }

  .empty-hint a {
    color: #111111;
    font-weight: 700;
  }

  @media (max-width: 900px) {
    .dashboard-header {
      flex-direction: column;
      align-items: stretch;
    }

    .dashboard-panel {
      grid-template-columns: 1fr;
    }

    .filter-card {
      position: static;
    }
  }
</style>
