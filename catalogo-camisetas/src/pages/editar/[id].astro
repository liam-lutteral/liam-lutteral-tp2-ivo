---
export const prerender = false;
import Layout from "../../layouts/Layout.astro";
const { id } = Astro.params;
---

<Layout title="Editar camiseta">
  <section class="page-shell">
    <div class="page-header">
      <span class="eyebrow">Editar camiseta</span>
      <h1>Modificá los detalles de la camiseta.</h1>
      <p>Actualizá equipo, temporada, tipo o imagen. Si la URL falla, se mostrará una imagen de respaldo.</p>
    </div>

    <div class="edit-grid">
      <form id="form-editar" class="product-form">
        <label>
          Equipo
          <input id="equipo" placeholder="Ej: Real Madrid" required />
        </label>
        <label>
          Temporada
          <input id="temporada" placeholder="Ej: 2024/25" />
        </label>
        <label>
          Tipo de equipación
          <select id="tipo">
            <option value="Titular">Titular</option>
            <option value="Suplente">Suplente</option>
            <option value="Alternativa">Alternativa</option>
          </select>
        </label>
        <label>
          Marca
          <input id="marca" placeholder="Ej: Adidas" />
        </label>
        <label>
          URL de imagen
          <input id="imagen_url" type="url" placeholder="https://..." />
        </label>
        <label>
          Descripción
          <textarea id="descripcion" placeholder="Descripción"></textarea>
        </label>

        <div class="form-actions">
          <button type="submit">Guardar cambios</button>
          <a class="cancel-link" href="/dashboard">Cancelar</a>
        </div>
        <p class="message" id="mensaje"></p>
      </form>

      <aside class="preview-card">
        <span class="eyebrow">Vista previa</span>
        <div class="preview-image-wrap">
          <img
            id="preview-image"
            src="/camisetas/front-slim.svg"
            alt="Vista previa de camiseta"
            onerror="this.onerror=null;this.src='/camisetas/front-slim.svg';"
          />
        </div>
        <div class="preview-meta">
          <span id="preview-equipo">Equipo</span>
          <span id="preview-tipo">Tipo: Titular</span>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script is:inline>window.__CAMISETA_ID__ = "{id}";</script>
<script src="../../scripts/editar.js"></script>

<style>
  .page-shell {
    display: grid;
    gap: 32px;
    padding: 18px 0 0;
    max-width: 980px;
  }

  .page-header {
    background: #ffffff;
    border-radius: 32px;
    padding: 34px;
    box-shadow: 0 30px 60px rgba(17, 17, 17, 0.08);
  }

  .eyebrow {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    font-size: 0.82rem;
    color: #7d7d7d;
    margin-bottom: 16px;
  }

  h1 {
    margin: 0;
    font-size: clamp(2rem, 3vw, 2.8rem);
    color: #111111;
  }

  p {
    margin-top: 16px;
    color: #555555;
    line-height: 1.75;
  }

  .edit-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(300px, 1fr);
    gap: 28px;
  }

  .product-form {
    display: grid;
    gap: 18px;
    background: #ffffff;
    border-radius: 32px;
    padding: 32px;
    box-shadow: 0 26px 70px rgba(17, 17, 17, 0.08);
  }

  label {
    display: grid;
    gap: 10px;
    color: #444444;
    font-weight: 600;
  }

  input,
  select,
  textarea {
    width: 100%;
    border: 1px solid #e3dcd2;
    background: #fbf8f2;
    border-radius: 16px;
    padding: 16px 18px;
    font-size: 1rem;
    color: #111111;
  }

  textarea {
    min-height: 140px;
    resize: vertical;
  }

  .form-actions {
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }

  button {
    border: 0;
    border-radius: 999px;
    padding: 16px 20px;
    background: #111111;
    color: #ffffff;
    font-weight: 700;
    cursor: pointer;
  }

  .cancel-link {
    color: #555555;
    font-weight: 600;
    text-decoration: none;
  }

  .cancel-link:hover {
    color: #111111;
  }

  .preview-card {
    background: #ffffff;
    border-radius: 32px;
    padding: 32px;
    box-shadow: 0 26px 70px rgba(17, 17, 17, 0.08);
    display: grid;
    gap: 22px;
    text-align: center;
    align-self: start;
  }

  .preview-image-wrap {
    height: 320px;
    border-radius: 28px;
    background: #f3efe5;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .preview-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .preview-meta {
    display: grid;
    gap: 12px;
    color: #555555;
    font-weight: 600;
  }

  .message {
    color: #d12f2f;
    margin-top: 8px;
    min-height: 22px;
  }

  @media (max-width: 840px) {
    .edit-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
