---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Catálogo de camisetas">
  <section class="hero">
    <div class="hero-copy">
      <span class="eyebrow">Catálogo de fútbol</span>
      <h1>Tu colección de camisetas, organizada y segura.</h1>
      <p>Registrate, cargá tus equipaciones (titular, suplente o alternativa) y gestioná tu catálogo personal con autenticación Supabase y seguridad RLS.</p>
      <div class="hero-actions">
        <a class="primary" href="/register">Crear cuenta</a>
        <a class="secondary" href="/login">Iniciar sesión</a>
      </div>
      <ul class="feature-list">
        <li>CRUD completo por usuario</li>
        <li>Imágenes por URL con respaldo automático</li>
        <li>Filtros por equipo, marca y tipo</li>
      </ul>
    </div>

    <div class="hero-preview">
      <div class="preview-card">
        <span class="preview-label">Vista previa</span>
        <img src="/camisetas/front-slim.svg" alt="Camiseta de catálogo" />
      </div>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    align-items: center;
    gap: 3rem;
    margin-top: 48px;
  }

  .hero-copy {
    max-width: 540px;
  }

  .eyebrow {
    display: inline-block;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #7c7c7c;
    font-size: 0.82rem;
    margin-bottom: 18px;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 4vw, 3.8rem);
    line-height: 1.05;
    color: #111111;
  }

  p {
    margin-top: 24px;
    color: #4e4e4e;
    line-height: 1.75;
    font-size: 1.05rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: 32px;
  }

  .primary,
  .secondary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 15px 26px;
    border-radius: 999px;
    font-weight: 700;
    text-decoration: none;
  }

  .primary {
    background: #111111;
    color: #ffffff;
  }

  .secondary {
    background: rgba(17, 17, 17, 0.06);
    color: #111111;
  }

  .feature-list {
    margin: 28px 0 0;
    padding-left: 20px;
    color: #555555;
    line-height: 1.9;
  }

  .hero-preview {
    display: flex;
    justify-content: center;
  }

  .preview-card {
    width: min(420px, 100%);
    border-radius: 32px;
    padding: 32px;
    background: #ffffff;
    box-shadow: 0 28px 80px rgba(17, 17, 17, 0.08);
    text-align: center;
  }

  .preview-label {
    display: block;
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 0.24em;
    color: #7d7d7d;
    font-size: 0.8rem;
  }

  .preview-card img {
    width: 100%;
    border-radius: 28px;
    background: #f2eee5;
  }
</style>
