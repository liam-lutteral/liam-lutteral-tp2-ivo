---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Catálogo de Camisetas">
  <section class="hero">
    <h1>Catálogo de camisetas de fútbol</h1>
    <p>Guardá, organizá y editá tus camisetas favoritas.</p>

    <a href="/register">Crear cuenta</a>
    <a href="/login">Iniciar sesión</a>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    margin-top: 80px;
  }

  h1 {
    font-size: 48px;
  }

  a {
    display: inline-block;
    margin: 10px;
    padding: 12px 20px;
    background: #0f8;
    color: #111;
    border-radius: 8px;
  }
</style>