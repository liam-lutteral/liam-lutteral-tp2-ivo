---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <title>{title}</title>
  </head>

  <body>
    <nav>
      <a href="/">Inicio</a>
      <a href="/login">Login</a>
      <a href="/register">Registro</a>
      <a href="/dashboard">Mi catálogo</a>
    </nav>

    <main>
      <slot />
    </main>
  </body>
</html>

<style>
  body {
    font-family: Arial, sans-serif;
    background: #111;
    color: white;
    margin: 0;
  }

  nav {
    padding: 20px;
    background: #1c1c1c;
    display: flex;
    gap: 20px;
  }

  a {
    color: white;
    text-decoration: none;
  }

  main {
    padding: 30px;
  }
</style>