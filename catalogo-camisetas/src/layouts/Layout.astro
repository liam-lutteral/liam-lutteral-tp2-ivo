---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <div class="shell">
      <nav class="topnav">
        <a class="brand" href="/">Catálogo</a>
        <div class="nav-links">
          <a href="/dashboard">Mi catálogo</a>
          <a href="/nueva">Agregar</a>
          <a href="/login">Login</a>
          <a href="/register">Registro</a>
        </div>
      </nav>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  :global(:root) {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f4efe7;
    color: #111111;
    text-rendering: optimizeLegibility;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: #f4efe7;
  }

  .shell {
    min-height: 100vh;
  }

  .topnav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 28px;
    gap: 16px;
    background: rgba(255, 255, 255, 0.95);
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(14px);
  }

  .brand {
    text-transform: uppercase;
    font-size: 1rem;
    letter-spacing: 0.22em;
    color: #111111;
    text-decoration: none;
    font-weight: 800;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
  }

  .topnav a {
    color: #444444;
    text-decoration: none;
    font-weight: 600;
    transition: color 180ms ease;
  }

  .topnav a:hover {
    color: #111111;
  }

  main {
    max-width: 1280px;
    width: min(100%, 1280px);
    margin: 0 auto;
    padding: 28px;
  }
</style>
