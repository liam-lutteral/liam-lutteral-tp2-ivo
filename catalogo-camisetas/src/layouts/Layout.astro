---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <div class="shell">
      <nav class="topnav">
        <a class="brand" href="/">Catálogo</a>
        <div class="nav-links" id="nav-links">
          <a href="/login" data-nav="guest">Iniciar sesión</a>
          <a href="/register" data-nav="guest">Registro</a>
          <span id="user-email" data-nav="auth" hidden></span>
          <a href="/dashboard" data-nav="auth" hidden>Mi catálogo</a>
          <a href="/nueva" data-nav="auth" hidden>Nueva camiseta</a>
          <button type="button" id="nav-logout" data-nav="auth" hidden>Cerrar sesión</button>
        </div>
      </nav>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<script type="module">
  import { supabase } from "../lib/supabase.js";

  const guestLinks = document.querySelectorAll('[data-nav="guest"]');
  const authLinks = document.querySelectorAll('[data-nav="auth"]');
  const logoutBtn = document.getElementById("nav-logout");
  const userEmail = document.getElementById("user-email");

  async function updateNav() {
    const { data } = await supabase.auth.getSession();
    const isLoggedIn = Boolean(data.session);

    guestLinks.forEach((el) => { el.hidden = isLoggedIn; });
    authLinks.forEach((el) => { el.hidden = !isLoggedIn; });

    if (isLoggedIn && userEmail && data.session?.user?.email) {
      userEmail.textContent = data.session.user.email;
    }
  }

  logoutBtn?.addEventListener("click", async () => {
    await supabase.auth.signOut();
    window.location.href = "/";
  });

  supabase.auth.onAuthStateChange(updateNav);
  updateNav();
</script>

<style>
  :global(:root) {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f4efe7;
    color: #111111;
    text-rendering: optimizeLegibility;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: #f4efe7;
  }

  .shell {
    min-height: 100vh;
  }

  .topnav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 28px;
    gap: 16px;
    background: rgba(255, 255, 255, 0.95);
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(14px);
  }

  .brand {
    text-transform: uppercase;
    font-size: 1rem;
    letter-spacing: 0.22em;
    color: #111111;
    text-decoration: none;
    font-weight: 800;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
  }

  #user-email {
    color: #111111;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 8px 16px;
    background: rgba(17, 17, 17, 0.06);
    border-radius: 999px;
  }

  .topnav a {
    color: #444444;
    text-decoration: none;
    font-weight: 600;
    transition: color 180ms ease;
  }

  .topnav a:hover {
    color: #111111;
  }

  #nav-logout {
    border: 0;
    background: rgba(17, 17, 17, 0.06);
    color: #444444;
    font-weight: 600;
    font-size: 1rem;
    padding: 8px 16px;
    border-radius: 999px;
    cursor: pointer;
    transition: color 180ms ease, background 180ms ease;
  }

  #nav-logout:hover {
    color: #111111;
    background: rgba(17, 17, 17, 0.1);
  }

  main {
    max-width: 1280px;
    width: min(100%, 1280px);
    margin: 0 auto;
    padding: 28px;
  }
</style>
