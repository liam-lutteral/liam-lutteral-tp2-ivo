---
const { title } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <div class="shell">
      <nav class="topnav">
        <a class="brand" href="/">Catálogo</a>
        <div class="nav-links" id="nav-links">
          <a href="/login" data-nav="guest">Iniciar sesión</a>
          <a href="/register" data-nav="guest">Registro</a>
          <a href="/dashboard" data-nav="auth" hidden>Mi catálogo</a>
          <a href="/nueva" data-nav="auth" hidden>Nueva camiseta</a>
          <span id="nav-email" data-nav="auth" hidden class="nav-email"></span>
          <button type="button" id="nav-logout" data-nav="auth" hidden>Cerrar sesión</button>
        </div>
      </nav>
      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<script src="../scripts/nav.js"></script>

<style>
  :global(:root) {
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    background: #f4efe7;
    color: #111111;
    text-rendering: optimizeLegibility;
  }

  *, *::before, *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background: #f4efe7;
  }

  .shell {
    min-height: 100vh;
  }

  .topnav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 22px 28px;
    gap: 16px;
    background: rgba(255, 255, 255, 0.95);
    border-bottom: 1px solid rgba(17, 17, 17, 0.08);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(14px);
  }

  .brand {
    text-transform: uppercase;
    font-size: 1rem;
    letter-spacing: 0.22em;
    color: #111111;
    text-decoration: none;
    font-weight: 800;
  }

  .nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 18px;
    align-items: center;
  }

  .topnav a {
    color: #444444;
    text-decoration: none;
    font-weight: 600;
    transition: color 180ms ease;
  }

  .topnav a:hover {
    color: #111111;
  }

  .nav-email {
    color: #7d7d7d;
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0 4px;
    max-width: 180px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  #nav-logout {
    border: 0;
    background: rgba(17, 17, 17, 0.06);
    color: #444444;
    font-weight: 600;
    font-size: 1rem;
    padding: 8px 16px;
    border-radius: 999px;
    cursor: pointer;
    transition: color 180ms ease, background 180ms ease;
  }

  #nav-logout:hover {
    color: #111111;
    background: rgba(17, 17, 17, 0.1);
  }

  main {
    max-width: 1280px;
    width: min(100%, 1280px);
    margin: 0 auto;
    padding: 28px;
  }
</style>
